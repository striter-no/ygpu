{
  "compiler": {
    "cc": "zig c++ -target aarch64-macos",
    "linker": "zig ar",
    "binary": "executable",
    "objects_path": ".objs"
  },

  "targets": {
    "release": {
      "flags": [
        "-D_GNU_SOURCE",
        "-DVK_NO_PROTOTYPES",
        "-DGLFW_INCLUDE_NONE",
        "-std=c++20"
      ],
      "optimization": "O3"
    },

    "debug": {
      "flags": [
        "-fsanitize=address",
        "-g",
        "-D_GNU_SOURCE",
        "-DGLFW_INCLUDE_NONE",
        "-DVK_NO_PROTOTYPES",
        "-std=c++20"
      ],
      "optimization": "O1"
    },

    "valgrind": {
      "flags": [
        "-g",
        "-D_GNU_SOURCE",
        "-DVK_NO_PROTOTYPES",
        "-std=c++20",
        "-DGLFW_INCLUDE_NONE"
      ],
      "optimization": "O1"
    },

    "debug-silent": {
      "flags": [
        "-g",
        "-D_GNU_SOURCE",
        "-DVK_NO_PROTOTYPES",
        "-DGLFW_INCLUDE_VULKAN",
        "-w"
      ],
      "optimization": "O1"
    }
  }
}
