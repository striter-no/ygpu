{
  "metadata": {
    "name": "example_window",
    "version": "0.0.0",
    "priority": 1000
  },

  "compiler": {
    "binary": "executable"
  },

  "dependencies": {
    "_": { "version": ">=0.0.0" }
  },

  "code": {
    "sources": ["**/*.cpp"],
    "output": "./bin/main-win.exe",
    "includes": ["include"],
    "libraries": ["glfw3", "gdi32", "user32", "shell32", "shaderc_combined", "glslang" ,"SPIRV" ,"SPIRV-Tools" ,"SPIRV-Tools-opt", "MachineIndependent" ,"GenericCodeGen" ,"OSDependent"],
    "lib-dirs": ["./lib/win"]
  },

  "target": "valgrind"
}
